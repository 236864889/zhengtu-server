	<!-- Npc定义，x和y分别指定Npc区域左上角的坐标，width和height分别指定Npc区域宽和高 -->
	<waypoint>
		<point x="5" y="5"/>
		<dest name="huangcheng" country="6" x="5" y="5"/>
